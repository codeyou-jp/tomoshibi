{
  "outputDirectory": "dist",
  "buildCommand": "npx expo export --platform web --output-dir dist && cp public/*.html dist/",
  "rewrites": [
    { "source": "/privacy.html", "destination": "/privacy.html" },
    { "source": "/terms.html", "destination": "/terms.html" },
    { "source": "/lp", "destination": "/lp.html" },
    { "source": "/lp.html", "destination": "/lp.html" },
    { "source": "/lp-white", "destination": "/lp-white.html" },
    { "source": "/lp-white.html", "destination": "/lp-white.html" },
    { "source": "/experience", "destination": "/experience.html" },
    { "source": "/experience.html", "destination": "/experience.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
